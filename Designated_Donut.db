-- View: Full_Order_Details
CREATE VIEW IF NOT EXISTS Full_Order_Details AS SELECT
    Orders.order_id,
    Users.name,
    Products.product_name,
    Products.product_type,
    Order_Items.quantity,
    Order_Items.purchase_price,
    Orders.total_price,
    Orders.order_date
FROM Orders
JOIN Users
ON Orders.user_id = Users.user_id
JOIN Order_Items
ON Orders.order_id = Order_Items.order_id
JOIN Products
ON Order_Items.product_id = Products.product_id;

-- View: Show_Products
CREATE VIEW IF NOT EXISTS Show_Products AS SELECT
    p.product_id,
    p.product_name,
    p.product_type,
    p.price
FROM Products AS p
ORDER BY p.product_id;

-- View: User_Login_Activity
CREATE VIEW IF NOT EXISTS User_Login_Activity AS SELECT
    Users.name,
    User_Sessions.login_times
FROM Users
JOIN User_Sessions
ON Users.user_id = User_Sessions.user_id;

COMMIT TRANSACTION;
PRAGMA foreign_keys = on;
